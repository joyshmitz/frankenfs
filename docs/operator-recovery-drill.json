      "rollback": {
        "rollback_available": true,
        "rollback_artifact": "artifacts/operator-recovery/refuse/pre-repair.snapshot",
        "rollback_or_refusal_outcome": "refused_before_mutation"
      },
      "expected_artifacts": [
        {
          "path": "artifacts/operator-recovery/refuse/refusal.json",
          "kind": "refusal_report",
          "required": true,
          "consumers": [
            "proof_bundle",
            "release_gate"
          ]
        },
        {
          "path": "artifacts/operator-recovery/refuse/manifest.json",
          "kind": "corruption_manifest",
          "required": true,
          "consumers": [
            "proof_bundle",
            "operational_readiness_report"
          ]
        }
      ],
      "expected_logs": [
        {
          "marker": "OPERATOR_RECOVERY_DRILL",
          "required_fields": [
            "exact_commands",
            "image_hashes",
            "corruption_manifest",
            "confidence_threshold",
            "repair_plan",
            "operator_warnings",
            "post_repair_verification",
            "rollback_or_refusal_outcome",
            "cleanup_status",
            "reproduction_command"
          ]
        }
      ],
      "cleanup": {
        "cleanup_status": "refused_before_mutation",
        "temp_paths_removed": true,
        "mount_unmounted": true
      },
      "proof_bundle_lane": "operator_recovery_drill",
      "reproduction_command": "cargo run -p ffs-harness -- validate-operator-recovery-drill --spec docs/operator-recovery-drill.json --select operator_refuse_low_confidence_multi_block"
    }
  ],
  "reproduction_command": "cargo run -p ffs-harness -- validate-operator-recovery-drill --spec docs/operator-recovery-drill.json --out artifacts/operator-recovery/drill_report.json --summary-out artifacts/operator-recovery/drill_summary.md"
}
