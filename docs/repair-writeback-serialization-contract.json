{
  "schema_version": 1,
  "contract_id": "bd-rchk0.1.1-repair-writeback-serialization-v1",
  "bead_id": "bd-rchk0.1.1",
  "current_policy": {
    "policy_id": "rw-repair-fail-closed-v1-historical",
    "read_write_repair_state": "fail_closed",
    "mutating_rw_repair_enabled": false,
    "serialization_point": "not_implemented",
    "fail_closed_error_class": "rw_repair_serialization_missing",
    "docs_wording_id": "readme.repair.rw.writeback"
  },
  "artifact_consumers": [
    "operator_proof_bundle",
    "release_gate_evaluator",
    "operational_readiness_report",
    "mounted_write_matrix"
  ],
  "required_evidence_fields": [
    "operation_id",
    "scenario_id",
    "snapshot_epoch",
    "lease_id",
    "repair_symbol_version",
    "expected_state",
    "observed_state",
    "error_class",
    "artifact_paths",
    "cleanup_status",
    "reproduction_command",
    "follow_up_bead"
  ],
  "invariants": [
    {
      "invariant_id": "I1_snapshot_epoch_cut",
      "description": "Every mounted request and repair attempt observes a single MVCC snapshot epoch; repair cannot write back data decoded from an epoch older than the client-visible block generation.",
      "required_log_fields": [
        "operation_id",
        "scenario_id",
        "snapshot_epoch",
        "expected_state",
        "observed_state"
      ],
      "failure_error_class": "mvcc_snapshot_boundary_violation"
    },
    {
      "invariant_id": "I2_single_writer_serializer",
      "description": "Client writes and repair writeback for overlapping blocks must enter the same serializer before either path may mutate live image state.",
      "required_log_fields": [
        "operation_id",
        "scenario_id",
        "expected_state",
        "observed_state",
        "error_class"
      ],
      "failure_error_class": "rw_repair_serialization_missing"
    },
    {
      "invariant_id": "I3_dirty_cache_before_repair",
      "description": "Repair writeback must not overwrite a block with dirty client data that has not crossed the fsync/fsyncdir durability boundary.",
      "required_log_fields": [
        "operation_id",
        "scenario_id",
        "snapshot_epoch",
        "error_class"
      ],
      "failure_error_class": "dirty_cache_not_fsynced"
    },
    {
      "invariant_id": "I4_fsync_fsyncdir_boundary",
      "description": "Only fsync and fsyncdir can publish durability evidence that a repair writeback may rely on; flush remains non-durable.",
      "required_log_fields": [
        "operation_id",
        "scenario_id",
        "expected_state",
        "observed_state",
        "error_class"
      ],
      "failure_error_class": "flush_non_durable"
    },
    {
      "invariant_id": "I5_repair_lease_exclusive",
      "description": "Mutating repair must hold an active per-image ownership lease before replacing source blocks or refreshing repair symbols.",
      "required_log_fields": [
        "operation_id",
        "scenario_id",
        "lease_id",
        "error_class"
      ],
      "failure_error_class": "lease_expired_or_missing"
    },
    {
      "invariant_id": "I6_repair_symbol_freshness",
      "description": "Repair symbols must match the current block generation before repair writeback can proceed.",
      "required_log_fields": [
        "operation_id",
        "scenario_id",
        "repair_symbol_version",
        "snapshot_epoch",
        "error_class"
      ],
      "failure_error_class": "stale_repair_symbol"
    },
    {
      "invariant_id": "I7_cancel_cleanup_no_partial_mutation",
      "description": "Cancellation must leave either no mutation or a fully ledgered cleanup state with no hidden partial repair.",
      "required_log_fields": [
        "operation_id",
        "scenario_id",
        "cleanup_status",
        "artifact_paths",
        "reproduction_command"
      ],
      "failure_error_class": "cancelled_repair_cleanup"
    },
    {
      "invariant_id": "I8_failure_refuses_symbol_refresh",
      "description": "A failed or halfway source-block writeback must not refresh repair symbols, because that would make stale parity look authoritative.",
      "required_log_fields": [
        "operation_id",
        "scenario_id",
        "repair_symbol_version",
        "error_class",
        "artifact_paths"
      ],
      "failure_error_class": "writeback_failure_no_refresh"
    }
  ],
  "states": [
    {
      "state_id": "detection_only_scrub",
      "description": "Mounted scrub can observe corruption and write evidence, but cannot mutate source blocks or symbols.",
      "client_writes_allowed": true,
      "repair_writeback_allowed": false,
      "mutates_image": false
    },
    {
      "state_id": "repair_planning",
      "description": "Corruption evidence is converted into a repair plan and confidence decision before any mutation is attempted.",
      "client_writes_allowed": true,
      "repair_writeback_allowed": false,
      "mutates_image": false
    },
    {
      "state_id": "repair_lease_held",
      "description": "A mutating repair path owns the per-image repair lease and can perform preflight checks.",
      "client_writes_allowed": false,
      "repair_writeback_allowed": false,
      "mutates_image": false
    },
    {
      "state_id": "client_write_in_flight",
      "description": "Mounted read-write client data or metadata mutation is active or dirty in cache.",
      "client_writes_allowed": true,
      "repair_writeback_allowed": false,
      "mutates_image": true
    },
    {
      "state_id": "fsync_boundary",
      "description": "All relevant client writes reached an fsync or fsyncdir boundary and are eligible for repair preflight.",
      "client_writes_allowed": true,
      "repair_writeback_allowed": false,
      "mutates_image": false
    },
    {
      "state_id": "repair_writeback_blocked_rw",
        "description": "Historical bd-rchk0.1.1 state: read-write mounted repair requested mutation before the unified serializer existed, so the path failed closed.",
      "client_writes_allowed": true,
      "repair_writeback_allowed": false,
      "mutates_image": false
    },
    {
      "state_id": "repair_writeback_staged",
        "description": "Decoded block writeback is staged behind the same serializer used by client writes.",
      "client_writes_allowed": false,
      "repair_writeback_allowed": true,
      "mutates_image": false
    },
    {
      "state_id": "repair_symbol_refresh",
      "description": "Future state: repair symbols are refreshed only after source block writeback is verified durable.",
      "client_writes_allowed": false,
      "repair_writeback_allowed": true,
      "mutates_image": true
    },
    {
      "state_id": "writeback_failure",
      "description": "Repair writeback failed or was interrupted; symbol refresh is refused and reproduction artifacts are preserved.",
      "client_writes_allowed": false,
      "repair_writeback_allowed": false,
      "mutates_image": false
    },
    {
      "state_id": "cleanup_complete",
      "description": "Lease, staging rows, and temporary artifacts reached a ledgered cleanup state.",
      "client_writes_allowed": true,
      "repair_writeback_allowed": false,
      "mutates_image": false
    }
  ],
  "transitions": [
    {
      "transition_id": "detect_to_plan",
      "from_state": "detection_only_scrub",
      "event": "corruption_detected",
      "to_state": "repair_planning",
      "allowed": true,
      "mutation_allowed": false,
      "error_class": "none",
      "guard": "detection-only evidence may be planned without mutation",
      "requires_active_lease": false,
      "requires_fresh_symbol": false,
      "requires_fsync_boundary": false,
      "required_evidence_fields": [
        "operation_id",
        "scenario_id",
        "snapshot_epoch",
        "artifact_paths",
        "reproduction_command"
      ]
    },
    {
      "transition_id": "plan_to_lease",
      "from_state": "repair_planning",
      "event": "lease_acquired",
      "to_state": "repair_lease_held",
      "allowed": true,
      "mutation_allowed": false,
      "error_class": "none",
      "guard": "mutating repair may proceed to preflight only after exclusive lease acquisition",
      "requires_active_lease": true,
      "requires_fresh_symbol": false,
      "requires_fsync_boundary": false,
      "required_evidence_fields": [
        "operation_id",
        "scenario_id",
        "lease_id",
        "expected_state",
        "observed_state"
      ]
    },
    {
      "transition_id": "rw_repair_fail_closed",
      "from_state": "client_write_in_flight",
      "event": "repair_writeback_requested",
      "to_state": "repair_writeback_blocked_rw",
      "allowed": false,
      "mutation_allowed": false,
      "error_class": "rw_repair_serialization_missing",
      "guard": "read-write mounted automatic repair has no unified serializer with client writes",
      "requires_active_lease": true,
      "requires_fresh_symbol": true,
      "requires_fsync_boundary": true,
      "required_evidence_fields": [
        "operation_id",
        "scenario_id",
        "snapshot_epoch",
        "lease_id",
        "repair_symbol_version",
        "expected_state",
        "observed_state",
        "error_class",
        "artifact_paths",
        "cleanup_status",
        "reproduction_command",
        "follow_up_bead"
      ],
      "follow_up_bead": "bd-rchk0.1.2"
    },
    {
      "transition_id": "flush_non_durable_rejects_repair",
      "from_state": "client_write_in_flight",
      "event": "flush_observed",
      "to_state": "client_write_in_flight",
      "allowed": false,
      "mutation_allowed": false,
      "error_class": "flush_non_durable",
      "guard": "flush cannot advance visible/durable state for repair writeback",
      "requires_active_lease": false,
      "requires_fresh_symbol": false,
      "requires_fsync_boundary": true,
      "required_evidence_fields": [
        "operation_id",
        "scenario_id",
        "expected_state",
        "observed_state",
        "error_class",
        "reproduction_command"
      ],
      "follow_up_bead": "bd-rchk0.1.1.1"
    },
    {
      "transition_id": "fsync_boundary_reaches_preflight",
      "from_state": "client_write_in_flight",
      "event": "fsync_or_fsyncdir_completed",
      "to_state": "fsync_boundary",
      "allowed": true,
      "mutation_allowed": false,
      "error_class": "none",
      "guard": "fsync/fsyncdir creates durable evidence but still does not authorize RW repair mutation",
      "requires_active_lease": false,
      "requires_fresh_symbol": false,
      "requires_fsync_boundary": true,
      "required_evidence_fields": [
        "operation_id",
        "scenario_id",
        "snapshot_epoch",
        "expected_state",
        "observed_state",
        "reproduction_command"
      ]
    },
    {
      "transition_id": "missing_boundary_rejects_repair",
      "from_state": "repair_lease_held",
      "event": "fsync_boundary_missing",
      "to_state": "repair_writeback_blocked_rw",
      "allowed": false,
      "mutation_allowed": false,
      "error_class": "dirty_cache_not_fsynced",
      "guard": "repair cannot use dirty or merely flushed client data as authoritative",
      "requires_active_lease": true,
      "requires_fresh_symbol": true,
      "requires_fsync_boundary": true,
      "required_evidence_fields": [
        "operation_id",
        "scenario_id",
        "snapshot_epoch",
        "lease_id",
        "error_class",
        "artifact_paths",
        "cleanup_status",
        "reproduction_command",
        "follow_up_bead"
      ],
      "follow_up_bead": "bd-rchk0.1.1.1"
    },
